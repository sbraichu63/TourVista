# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DJANGO SECURITY SETTINGS (REQUIRED)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# SECRET_KEY - MUST be changed for production!
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# IMPORTANT: Keep this secret and never commit to version control
SECRET_KEY=your-secret-key-here

# DEBUG Mode - Set to False in production!
# Setting DEBUG=True exposes sensitive information in error pages
# Development: DEBUG=True
# Production: DEBUG=False
DEBUG=False

# Allowed Hosts - Comma-separated list of domain names
# Development: localhost,127.0.0.1
# Production: yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EMAIL CONFIGURATION (Optional - defaults to console output in DEBUG mode)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# THIRD-PARTY API KEYS (Optional - features degrade gracefully if not set)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Weather API - Get free from https://openweathermap.org/api
# If not set: Weather feature returns mock data
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key

# Google Gemini API - Get free from https://aistudio.google.com/
# If not set: Chatbot uses rule-based responses instead
GEMINI_API_KEY=your_gemini_api_key

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE CONFIGURATION (Optional - defaults to SQLite)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=tourvista_db
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SETUP INSTRUCTIONS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 
# 1. RENAME THIS FILE:
#    Copy this file and rename to .env (remove .example)
#    
# 2. GENERATE SECRET_KEY:
#    python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#    
# 3. FOR DEVELOPMENT:
#    - Keep DEBUG=True (optional)
#    - ALLOWED_HOSTS=localhost,127.0.0.1
#    
# 4. FOR PRODUCTION:
#    - Set DEBUG=False (CRITICAL!)
#    - Generate a new SECRET_KEY
#    - Add your domain to ALLOWED_HOSTS
#    - Configure EMAIL settings for sending real emails
#    
# 5. SECURITY:
#    - Add .env to .gitignore (don't commit secrets!)
#    - Keep API keys confidential
#    - Use strong SECRET_KEY
#
