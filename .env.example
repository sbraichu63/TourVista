# TourVista Environment Configuration

# ────────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT vs PRODUCTION
# 
# For Development:
#   - DEBUG=True
#   - SECRET_KEY can be auto-generated (will change on restart)
#   - DATABASE_URL not needed (uses SQLite)
#
# For Production (Render):
#   - DEBUG=False
#   - SECRET_KEY MUST be set to a strong random value
#   - DATABASE_URL required for PostgreSQL connection
# ────────────────────────────────────────────────────────────────────────────────

# Django Settings
DEBUG=True
SECRET_KEY=your-super-secret-key-here-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Leave empty for SQLite in development)
# For Production: DATABASE_URL=postgresql://user:password@hostname:5432/dbname
DATABASE_URL=

# Security - PRODUCTION ONLY
CSRF_TRUSTED_ORIGINS=https://localhost,https://yourdomain.com,https://www.yourdomain.com

# Email Configuration (Gmail App Password recommended for production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=TourVista <noreply@yourdomain.com>

# Optional API Keys
OPENWEATHERMAP_API_KEY=
GEMINI_API_KEY=

